flowchart LR
  User[User Browser] --> Site[S3 Static Website]
  Site --> API[API Gateway HTTP API]
  API --> Orders[Lambda Create PayPal Order]
  API --> Capture[Lambda Capture PayPal Order]
  API --> Upload[Lambda Create S3 Presigned URL]
  API --> Start[Lambda Start Processing]
  Orders --> PayPal[PayPal Orders API]
  Capture --> PayPal
  Orders --> DDB[DynamoDB Jobs]
  Capture --> DDB
  Upload --> Raw[S3 Raw Uploads]
  Start --> SFN[Step Functions]
  SFN --> Processor[Lambda Process Media]
  Processor --> Rekognition[Amazon Rekognition]
  Processor --> Comprehend[Amazon Comprehend]
  Processor --> Results[S3 Results Bucket]
  Processor --> DDB
  API --> Status[Lambda Get Job]
  Status --> DDB
